{{# 
	The footer menu, referred to as the utility menu.
	Links can be added/removed from this list in /_data.json 
#}}
{{ if site.footer.footer_links.length >= 1 }}
  <div class="utility-links">

    {{ for footer_link of site.footer.footer_links }}
      <a href="{{footer_link.link }}">
        {{ footer_link.title.toUpperCase() }}
      </a>
    {{ /for }}
  </div>
{{ /if }}
