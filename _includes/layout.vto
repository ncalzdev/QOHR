<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="/styles.css">
    <link rel="icon" href="/assets/icons/NCD_Logo.png" type="image/x-icon">
    <title>{{ site.name }}</title>
      <style>
		{{ if site.use_background_pattern }}
			:root {
				--transparency: {{ site.background_alpha }};
			}
			:root[data-theme="light"] {
				--background-pattern: url({{ site.background_pattern_lightmode |> url
				}});
			}
			:root[data-theme="dark"] {
				--background-pattern: url({{ site.background_pattern_darkmode |> url
				}});
			}
		{{ else }}
			:root {
				--transparency: {{ site.background_alpha }};
			}
		{{ /if }}
		:root {
			{{ if site.footer.footer_background }}
				--footer-background: url({{ site.footer.footer_background }});
			{{ /if }}

			{{ if site.background_pattern_size }} {{# Refers to the width of the background pattern image #}}
				--background-pattern-size: {{ site.background_pattern_size }};
			{{ else }}
				--background-pattern-size: 300px;
			{{ /if }}
		}
      </style>
  </head>
  <body>
    <header class="spread">
      {{ include "/partials/header.vto" }}
    </header>

    <main>
      {{ content |> safe }}
    </main>

    <footer>
      {{ include "/partials/footer.vto" }}
    </footer>

	{{# Scripts #}}
		{{# Hamburger menu toggle #}}
		<script src="/assets/scripts/menu.js" defer></script>
		
		{{# Theme selector handling #}}
		<script src="/assets/scripts/theme-selector.js" defer></script>
	{{# End Scripts #}}
  </body>
</html>
